# ── Authentication ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Generate a strong random key for production. Without this, sessions
# will NOT persist across server restarts.
# Example: python -c "import os; print(os.urandom(32).hex())"
SECRET_KEY=change-this-secret-key

# Session lifetime in seconds (default: 3600 = 1 hour)
SESSION_LIFETIME_SECONDS=3600

# ── Crowd Detection ──────────────────────────────────────────────────────
CROWD_THRESHOLD=10
ALERT_COOLDOWN=30

# ── Camera Source ─────────────────────────────────────────────────────────
# Webcam index example: 0, 1, 2
# Mobile camera stream example: http://192.168.1.50:8080/video
CAMERA_SOURCE=0

# ── History & Display ─────────────────────────────────────────────────────
HEATMAP_WINDOW_SECONDS=10
HISTORY_RECORD_INTERVAL_SECONDS=5

# ── Tracking & Density Fallback ───────────────────────────────────────────
USE_BYTETRACK=false
USE_CSRNET_FALLBACK=false
CSRNET_THRESHOLD=30
CSRNET_MODEL_PATH=PartAmodel_best.pth.tar

# ── Email Notifications (SMTP) ────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_FROM=

# ── Webhook Notifications ────────────────────────────────────────────────
WEBHOOK_URL=